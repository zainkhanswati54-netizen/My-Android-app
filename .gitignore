# =============================================================
#  Titan AI Studio Pro — .gitignore
# =============================================================

# ── Buildozer build output ───────────────────────────────────
.buildozer/
bin/
build.log

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# ── Virtual environments ─────────────────────────────────────
venv/
env/
.venv/
.env/

# ── Android / Java ───────────────────────────────────────────
*.apk
*.aab
*.keystore
*.jks
*.class

# ── App data / user files ────────────────────────────────────
*.json
!package.json
*.db
*.sqlite

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────
*.log

# ── Secrets (NEVER commit these) ─────────────────────────────
*.env
secrets.py
api_keys.py
