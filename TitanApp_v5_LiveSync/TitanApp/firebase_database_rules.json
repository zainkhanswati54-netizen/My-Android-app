{
  "rules": {
    // ── Admin section: any logged-in user can read/write ──
    // (Admin access is protected by PIN inside the app)
    "admin": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },
    // ── Per-user data: only that user can read/write ──
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    // ── Public read for app config ──
    "app_config": {
      ".read":  true,
      ".write": "auth != null"
    },
    // ── Default: deny all ──
    ".read":  false,
    ".write": false
  }
}
