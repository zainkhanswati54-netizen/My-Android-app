{
  "rules": {
    "admin": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "app_config": {
      ".read":  true,
      ".write": "auth != null"
    },
    "tts_logs": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "user_history": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    ".read":  false,
    ".write": false
  }
}
