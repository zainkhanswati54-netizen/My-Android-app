{
  "rules": {
    "admin": {
      ".read": "auth != null",
      ".write": "auth != null",
      "admins": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "app_config": {
      ".read": true,
      ".write": "auth != null"
    },
    "tts_logs": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child(\"admin/admins\").child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "user_history": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    ".read": false,
    ".write": false,
    "otp_store": {
      ".read": true,
      ".write": true,
      "$emailKey": {
        ".read": true,
        ".write": true
      }
    }
  }
}